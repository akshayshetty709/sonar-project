# Download kops
curl -Lo kops https://github.com/kubernetes/kops/releases/download/v1.28.0/kops-linux-amd64

# Make it executable and move to PATH
chmod +x kops
sudo mv kops /usr/local/bin/kops

# Verify installation
kops version

curl -LO "https://dl.k8s.io/release/$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl"
chmod +x kubectl
sudo mv kubectl /usr/local/bin/kubectl

kops create cluster \
  --name=${NAME} \
  --state=${KOPS_STATE_STORE} \
  --zones=ap-south-1a \
  --node-count=2 \
  --node-size=t3.medium \
  --master-size=t3.medium \
  --ssh-public-key=~/.ssh/id_rsa.pub \
  --yes

aws ec2 describe-instances \
  --region ap-south-1 \
  --filters "Name=tag:KubernetesCluster,Values=mycluster.k8s.local" \
  --query 'Reservations[].Instances[].{Name:Tags[?Key==`Name`].Value|[0],State:State.Name}' \
  --output table


kops validate cluster --wait 20m
aws autoscaling describe-auto-scaling-groups \
  --region ap-south-1 \
  --query 'AutoScalingGroups[?contains(AutoScalingGroupName,`mycluster`)].{Name:AutoScalingGroupName,Desired:DesiredCapacity}' \
  --output table

aws autoscaling describe-scaling-activities \
  --region ap-south-1 \
  --query 'Activities[0:3].{Status:StatusCode,Cause:Cause}' \
  --output table


aws service-quotas get-service-quota \
  --service-code ec2 \
  --quota-code L-1216C47A \
  --region ap-south-1 \
  --query 'Quota.Value'

aws autoscaling describe-scaling-activities \
  --auto-scaling-group-name control-plane-ap-south-1a.masters.mycluster.k8s.local \
  --region ap-south-1 \
  --query 'Activities[0].{Status:StatusCode,Cause:Cause,Description:Description,StatusMessage:StatusMessage}' \
  --output json

spec:
  docker:
    insecureRegistries:
      - "13.207.26.205:80"
  # OR if using containerd
  containerd:
    registryConfigs:
      13.207.26.205:80:
        insecure: true

kops update cluster ${NAME} --yes
kops rolling-update cluster ${NAME} --yes

kubectl create secret docker-registry harbor-creds \
  --docker-server=13.207.26.205:80 \
  --docker-username=<your-harbor-user> \
  --docker-password=<your-harbor-password>

    spec:
      containers:
      - name: api-gateway
        image: 13.207.26.205:80/my-project/gatewayservice:latest
      imagePullSecrets:
      - name: harbor-creds
    ```

